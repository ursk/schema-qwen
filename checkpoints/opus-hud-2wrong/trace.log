    bx = min(x for x, y in cs)
    by = min(y for x, y in cs)
    base = [row[:] for row in grid]
    for yy in range(by, by + 5):
        for xx in range(bx, bx + 5):
            base[yy][xx] = 3
    bar_cols = sorted(x for x in range(64) if grid[61][x] == 11)
    return {"base": base, "bx": bx, "by": by, "cnt": 0, "bar": bar_cols}

def _can_place(base, bx, by):
    if bx < 0 or by < 0 or bx + 5 > 64 or by + 5 > 64:
        return False
    for yy in range(by, by + 5):
        for xx in range(bx, bx + 5):
            if base[yy][xx] in (4, 9):
                return False
    return True

def step(state, action):
    bx, by = state["bx"], state["by"]
    d = {1: (0, -5), 2: (0, 5), 3: (-5, 0), 4: (5, 0)}
    nbx, nby = bx, by
    if action in d:
        dx, dy = d[action]
        if _can_place(state["base"], bx + dx, by + dy):
            nbx, nby = bx + dx, by + dy
    return {"base": state["base"], "bx": nbx, "by": nby,
            "cnt": state["cnt"] + 1, "bar": state["bar"]}

