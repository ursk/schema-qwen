            g[by + i][xx] = 12 if i < 2 else 9
    for k in range(min(state["cnt"], len(state["bar"]))):
        col = state["bar"][k]
        g[61][col] = 3
        g[62][col] = 3
    return g

def is_goal(state):
    return False
